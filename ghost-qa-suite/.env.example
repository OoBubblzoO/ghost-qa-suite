# Copy to .env and fill in. Never commit .env.

GHOST_BASE_URL=http://localhost:2368

# From Ghost admin: Settings -> Integrations -> Add custom integration
GHOST_CONTENT_API_KEY=
GHOST_ADMIN_API_KEY=            # format: <id>:<secret>

# Owner account you created during Ghost's one-time setup (used by E2E tests)
GHOST_ADMIN_EMAIL=
GHOST_ADMIN_PASSWORD=

# Tip: `python scripts/provision_ghost.py > .env` does all of this for you
# on a fresh local Ghost instance.
